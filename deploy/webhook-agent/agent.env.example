# MikroTik NMS deploy webhook agent — runtime configuration
#
# Copy to /etc/mikrotik-nms-deploy-agent/env (the install script does this)
# and edit. The agent reads these as environment variables on startup.

# === REQUIRED ===

# Shared HMAC secret used to validate GitHub webhook payloads.
# Generate with:  openssl rand -hex 32
# This is also the value you paste into GitHub → repo settings → Webhooks →
# "Secret".
WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# Repository the agent will accept push events from. Format: owner/repo.
# Anything else is rejected with 200 + "ignored" so GitHub stops retrying.
ALLOWED_REPO=c0de-ch/mikrotik-c0de

# Shell command to execute when a valid push arrives.
# Run via /bin/sh -c, so you can use pipes/redirects/&&. The DEPLOY_COMMIT
# environment variable will be set to the pushed commit SHA.
# See run.sh.example for a working starting point.
DEPLOY_COMMAND=/etc/mikrotik-nms-deploy-agent/run.sh

# === OPTIONAL — defaults shown ===

# Address to listen on. Bind to 127.0.0.1 if you front the agent with a
# reverse proxy on the same host (recommended).
LISTEN=127.0.0.1:9000

# Git ref to react to. Pushes to any other ref are ignored.
ALLOWED_REF=refs/heads/main

# Maximum wall-clock duration of a single deploy. The exec.Cmd is killed
# when this elapses. Format: Go duration string (e.g. 30m, 1h, 5m30s).
DEPLOY_TIMEOUT=30m
