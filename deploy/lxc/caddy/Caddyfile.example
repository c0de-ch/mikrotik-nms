# The site address is rewritten by install.sh.
# Examples after substitution:
#   nms.example.com           → auto Let's Encrypt
#   nms.lan                   → Caddy "tls internal" (self-signed)
#   http://nms.lan            → plain HTTP on :80
#   :80                       → plain HTTP on all hostnames
@@SITE@@ {
	encode gzip zstd

	# Backend: REST API + WebSocket (chi router serves both under /api/v1/*).
	# X-Forwarded-Proto / X-Forwarded-Host / X-Forwarded-For are added by
	# Caddy's reverse_proxy by default; no header_up directives needed.
	handle /api/* {
		reverse_proxy 127.0.0.1:8080
	}

	# Next.js _next/static/* assets are content-hashed; keep the long
	# immutable cache that the upstream sets so repeat loads are instant.
	handle /_next/static/* {
		reverse_proxy 127.0.0.1:3000
	}

	# All other Next.js responses (HTML, RSC payloads, API-route stubs)
	# upstream sets `cache-control: s-maxage=31536000` which makes shared
	# caches (and some browsers) keep stale HTML across deploys. After a
	# rebuild the bundle hash changes; a cached HTML referencing the old
	# hash 404s on every chunk → blank tab that never recovers. Force a
	# revalidate-every-time policy on the entrypoint while leaving
	# /_next/static/* free to cache forever.
	handle {
		reverse_proxy 127.0.0.1:3000
		# `>` defers the directive so it runs AFTER reverse_proxy and
		# overwrites the upstream's Cache-Control instead of duplicating it.
		header >Cache-Control "no-store, must-revalidate"
		header >-Pragma
		header >-Expires
	}

	# Reasonable security headers (frontend is same-origin via this proxy).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
