# The site address is rewritten by install.sh.
# Examples after substitution:
#   nms.example.com           → auto Let's Encrypt
#   nms.lan                   → Caddy "tls internal" (self-signed)
#   http://nms.lan            → plain HTTP on :80
#   :80                       → plain HTTP on all hostnames
@@SITE@@ {
	encode gzip zstd

	# Backend: REST API + WebSocket (chi router serves both under /api/v1/*).
	# X-Forwarded-Proto / X-Forwarded-Host / X-Forwarded-For are added by
	# Caddy's reverse_proxy by default; no header_up directives needed.
	handle /api/* {
		reverse_proxy 127.0.0.1:8080
	}

	# Everything else: Next.js frontend
	handle {
		reverse_proxy 127.0.0.1:3000
	}

	# Reasonable security headers (frontend is same-origin via this proxy).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		Referrer-Policy           "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
