# MikroTik NMS — Proxmox bootstrap configuration
#
# Copy this file to proxmox-create.env (alongside proxmox-create.sh) and fill
# in the values, then run:
#
#     ./proxmox-create.sh
#
# proxmox-create.env is gitignored implicitly because it contains secrets —
# do NOT commit your real values.

# === REQUIRED ===

# Proxmox web UI URL (the same one you log into).
PROXMOX_URL=https://pve.lan:8006

# Proxmox API token. Format: USER@REALM!TOKENID=SECRET
# Create one in Datacenter → Permissions → API Tokens.
# Easiest permission setup: assign role "PVEAdmin" on path "/" for the token.
# (For least-privilege, see the README "Required token permissions" section.)
PROXMOX_TOKEN=root@pam!nms-deploy=00000000-0000-0000-0000-000000000000

# Proxmox node that will host the LXC (the hostname shown in the cluster tree).
PROXMOX_NODE=pve

# VMID for the new LXC. Must NOT already exist.
LXC_VMID=200

# Hostname for the LXC.
LXC_HOSTNAME=mikrotik-nms

# === SSH AUTH (one of these is required) ===

# RECOMMENDED: path to a public key file. The script will inject it into
# root's authorized_keys on container creation, then SSH in using the matching
# private key.
LXC_SSH_PUBKEY=/home/you/.ssh/id_ed25519.pub
LXC_SSH_PRIVKEY=/home/you/.ssh/id_ed25519

# Fallback: a root password to set on the container. Requires `sshpass` on
# the local machine. Less secure — leaks via process listings on the host
# running this script. Comment out if using a key.
#LXC_PASSWORD=change-me-once-then-rotate

# === OPTIONAL — sensible defaults shown ===

# Storage where the LXC root disk will live.
LXC_STORAGE_ROOTFS=local-lvm

# Storage where ISO/template images live (the script will download the
# Debian template here if missing).
LXC_STORAGE_TEMPLATES=local

# Network bridge.
LXC_NETWORK_BRIDGE=vmbr0

# Network mode. Either "dhcp" or a static spec like:
#   ip=192.0.2.50/24,gw=192.0.2.1
LXC_NETWORK=dhcp

# Container resources.
LXC_CORES=2
LXC_MEMORY=1024     # MB
LXC_SWAP=512        # MB
LXC_DISK_GB=8

# Substring used to find the Debian template in the storage / aplinfo list.
# Match newest "debian-13-standard_*" by default.
LXC_TEMPLATE_PATTERN=debian-13-standard

# Set to 0 if your Proxmox uses a self-signed cert and you have not imported
# the CA on the machine running this script.
PROXMOX_VERIFY_TLS=1

# === APP DEPLOYMENT KNOBS ===

# Where to clone the repo on the LXC.
NMS_SRC_DIR=/opt/src/mikrotik-nms

# Repo + ref to clone.
NMS_REPO_URL=https://github.com/c0de-ch/mikrotik-c0de.git
NMS_REPO_REF=main

# Flags passed to deploy/lxc/install.sh inside the LXC.
# See deploy/lxc/install.sh --help for the full list. Common choices:
#   --no-tls                              # plain HTTP on the LXC IP
#   --hostname nms.lan                    # Caddy site = nms.lan (auto-TLS)
#   --no-tls --public-url http://nms.lan  # plain HTTP on a hostname
NMS_INSTALL_FLAGS=--no-tls
