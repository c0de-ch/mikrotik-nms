FROM golang:alpine AS builder
ENV GOTOOLCHAIN=local
RUN apk add --no-cache git
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /mikrotik-nms ./cmd/mikrotik-nms

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /mikrotik-nms /usr/local/bin/mikrotik-nms
EXPOSE 8080
ENTRYPOINT ["mikrotik-nms"]
