# Required
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Optional — encryption key for device passwords stored in DB
ENCRYPTION_KEY=

# Default RouterOS credentials (used when adding devices without explicit credentials)
DEFAULT_ROS_USER=admin
DEFAULT_ROS_PASS=

# Frontend URLs (for Docker Compose — adjust if using reverse proxy)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
