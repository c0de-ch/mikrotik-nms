# MikroTik NMS — Docker Compose environment file
#
# Copy to `.env` and fill in. Variables consumed directly by docker-compose.yml
# are unprefixed (JWT_SECRET, ENCRYPTION_KEY, DEFAULT_ROS_*); inside the
# backend container they are exposed as MIKROTIK_NMS_* — see docker-compose.yml.
# For native installs (LXC / systemd / K8s) set the MIKROTIK_NMS_* names
# directly in the service environment.

# ---- required ----
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ---- optional: device password encryption ----
# AES key (32+ random bytes / 64 hex chars) for encrypting RouterOS passwords
# in the SQLite `devices.password_enc` column. Leave blank to store plain.
ENCRYPTION_KEY=

# ---- optional: defaults applied to newly added devices ----
DEFAULT_ROS_USER=admin
DEFAULT_ROS_PASS=

# ---- frontend (baked into the JS bundle at build time) ----
# Adjust if you put a reverse proxy in front of the stack.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ---- optional polling intervals (durations like "30s", "5m", "6h") ----
# Uncomment and set in docker-compose.yml's `environment:` block, or pass
# directly to the container. Defaults are shown.
#
# MIKROTIK_NMS_HEALTH_INTERVAL=30s
# MIKROTIK_NMS_TOPOLOGY_INTERVAL=60s
# MIKROTIK_NMS_FIRMWARE_INTERVAL=6h
# MIKROTIK_NMS_NETWORK_HEALTH_INTERVAL=60s
# MIKROTIK_NMS_RETENTION_INTERVAL=1h
# MIKROTIK_NMS_RETENTION_DAYS=7

# ---- optional RouterOS connection defaults ----
# MIKROTIK_NMS_DEFAULT_ROS_PORT=8728
# MIKROTIK_NMS_DEFAULT_ROS_TLS=false

# Note: WiFi tracking, client-discovery cadence, the Kea Control Agent URL,
# and DNS resolvers are configured at runtime via the Settings page (stored
# in the app_settings table) — no env vars needed.
